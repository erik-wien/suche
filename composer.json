{
    "name": "erikr/suche",
    "description": "Search portal for jardyx.com/s",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../auth"},
        {"type": "path", "url": "../chrome"}
    ],
    "require": {
        "php": ">=8.2",
        "erikr/auth": "*",
        "erikr/chrome": "*",
        "symfony/yaml": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "ErikR\\Suche\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
